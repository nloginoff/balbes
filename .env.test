# Testing Environment Configuration

# Environment
ENV=test
DEBUG=true

# PostgreSQL (test instance on different port)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=balbes_test
POSTGRES_PASSWORD=balbes_test_secret
POSTGRES_DB=balbes_test

# Redis (test instance on different port)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PREFIX=test

# Qdrant (test instance on different port)
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION_PREFIX=test

# Service Ports (Testing: 9100-9299)
MEMORY_SERVICE_PORT=9100
SKILLS_REGISTRY_PORT=9101
ORCHESTRATOR_PORT=9102
CODER_PORT=9103
WEB_BACKEND_PORT=9200

# Service URLs
MEMORY_SERVICE_URL=http://localhost:9100
SKILLS_REGISTRY_URL=http://localhost:9101
ORCHESTRATOR_URL=http://localhost:9102
CODER_URL=http://localhost:9103

# Frontend
FRONTEND_PORT=5174

# API Keys (testing - use fake keys)
OPENROUTER_API_KEY=sk-or-test-fake-key
TELEGRAM_BOT_TOKEN=

# JWT (testing - simple key)
JWT_SECRET_KEY=test-jwt-secret-key-for-testing
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging
LOG_LEVEL=INFO
