# Production Environment Configuration

# Environment
ENV=prod
DEBUG=false

# PostgreSQL (production)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=balbes
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=balbes

# Redis (production with password)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
REDIS_PREFIX=prod

# Qdrant (production with API key)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=CHANGE_ME_QDRANT_API_KEY_HERE
QDRANT_COLLECTION_PREFIX=prod

# Service Ports (Production: 8100-8299)
MEMORY_SERVICE_PORT=8100
SKILLS_REGISTRY_PORT=8101
ORCHESTRATOR_PORT=8102
CODER_PORT=8103
WEB_BACKEND_PORT=8200

# Service URLs
MEMORY_SERVICE_URL=http://localhost:8100
SKILLS_REGISTRY_URL=http://localhost:8101
ORCHESTRATOR_URL=http://localhost:8102
CODER_URL=http://localhost:8103

# Frontend (served by Nginx on port 80/443)
FRONTEND_PORT=80

# API Keys (PRODUCTION - MUST CHANGE!)
OPENROUTER_API_KEY=your-real-openrouter-api-key-here
TELEGRAM_BOT_TOKEN=your-real-telegram-bot-token-here

# JWT (PRODUCTION - MUST BE STRONG!)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Logging
LOG_LEVEL=INFO

# Security
ALLOWED_ORIGINS=http://localhost,https://yourdomain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
