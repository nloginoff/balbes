# Development Environment Configuration

# Environment
ENV=dev
DEBUG=true

# PostgreSQL (shared instance, different database)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=balbes
POSTGRES_PASSWORD=balbes_secret
POSTGRES_DB=balbes_dev

# Redis (shared instance, different prefix)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PREFIX=dev

# Qdrant (shared instance, different collection)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_PREFIX=dev

# RabbitMQ (enabled in dev for production-like parity)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Service Ports (Development: 8100-8299)
MEMORY_SERVICE_PORT=8100
SKILLS_REGISTRY_PORT=8101
ORCHESTRATOR_PORT=8102
CODER_PORT=8103
WEB_BACKEND_PORT=8200

# Service URLs
MEMORY_SERVICE_URL=http://localhost:8100
SKILLS_REGISTRY_URL=http://localhost:8101
ORCHESTRATOR_URL=http://localhost:8102
CODER_URL=http://localhost:8103

# Frontend
FRONTEND_PORT=5173

# API Keys (development - replace with real keys locally)
OPENROUTER_API_KEY=sk-or-v1-your-dev-key-here
TELEGRAM_BOT_TOKEN=

# Web Auth (development)
WEB_AUTH_TOKEN=dev-web-auth-token
JWT_SECRET=dev-jwt-secret-key-not-for-production
JWT_SECRET_KEY=dev-jwt-secret-key-not-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=admin123

# Logging
LOG_LEVEL=DEBUG
