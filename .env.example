# =============================================================================
# Balbes Multi-Agent System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file with real secrets to git!

# =============================================================================
# LLM Providers
# =============================================================================
# OpenRouter API key (get from https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# AiTunnel API key (fallback provider)
AITUNNEL_API_KEY=your-aitunnel-key-here

# =============================================================================
# Telegram Bot
# =============================================================================
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_USER_ID=123456789

# =============================================================================
# Web UI Authentication
# =============================================================================
# Secret token for login (generate random 32+ chars)
WEB_AUTH_TOKEN=your-secure-random-token-here-min-32-chars

# JWT secret for sessions (generate random 32+ chars)
JWT_SECRET=your-jwt-secret-key-min-32-chars

# JWT expiration in hours
JWT_EXPIRATION_HOURS=24

# =============================================================================
# Webhooks gateway (services/webhooks_gateway — Telegram / MAX / monitoring notify)
# =============================================================================
WEBHOOKS_GATEWAY_PORT=8180
# polling = orchestrator telegram_bot.py uses long polling; webhook = only webhooks_gateway
TELEGRAM_BOT_MODE=polling
# Optional: same value as setWebhook(secret_token=...); header X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=
# Optional: HMAC secret for inbound MAX POST /webhook/max (header X-Signature)
MAX_WEBHOOK_SECRET=
# Bearer token for external monitoring (RU server). If empty, notify is disabled.
WEBHOOK_NOTIFY_API_KEY=
# Comma-separated: telegram, max
NOTIFY_DELIVERY_CHANNELS=telegram
# Optional Telegram chat_id override; if unset, TELEGRAM_USER_ID is used (private chat with bot)
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_RATE_LIMIT_PER_MINUTE=60
# MAX messenger (optional; required for max in NOTIFY_DELIVERY_CHANNELS)
MAX_BOT_TOKEN=
MAX_API_URL=https://platform-api.max.ru
NOTIFY_MAX_CHAT_ID=

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=balbes_agents
POSTGRES_USER=balbes
POSTGRES_PASSWORD=your-strong-password-here

# =============================================================================
# Redis (Fast Memory)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Qdrant (Vector Database)
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# =============================================================================
# RabbitMQ (Message Bus)
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_MANAGEMENT_PORT=15672

# =============================================================================
# Service Ports (for development)
# =============================================================================
ORCHESTRATOR_PORT=8000
CODER_PORT=8001
MEMORY_SERVICE_PORT=8100
SKILLS_REGISTRY_PORT=8101
WEB_BACKEND_PORT=8200
WEB_FRONTEND_PORT=5173

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory
LOG_DIR=./data/logs

# Log format: json or text
LOG_FORMAT=json

# Log file rotation
LOG_ROTATION_SIZE=100MB
LOG_RETENTION_DAYS=7

# =============================================================================
# Token Limits (defaults, can be overridden per agent in config)
# =============================================================================
# Daily token limit per agent
DEFAULT_DAILY_TOKEN_LIMIT=100000

# Hourly token limit per agent
DEFAULT_HOURLY_TOKEN_LIMIT=15000

# Alert threshold (0.8 = alert at 80% usage)
TOKEN_ALERT_THRESHOLD=0.8

# =============================================================================
# Performance & Timeouts
# =============================================================================
# Maximum task execution time in seconds (10 minutes)
TASK_TIMEOUT_SECONDS=600

# Maximum retries for failed operations
MAX_RETRIES=3

# Delay between retries in seconds
RETRY_DELAY_SECONDS=1

# Database connection pool size
CONNECTION_POOL_SIZE=10

# =============================================================================
# Development Settings
# =============================================================================
# Enable debug mode (verbose logging, detailed errors)
DEBUG=false

# Enable hot reload for uvicorn (development only)
RELOAD=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Production Settings (uncomment for production)
# =============================================================================
# Use Docker network names instead of localhost in production
# POSTGRES_HOST=postgres
# REDIS_HOST=redis
# QDRANT_HOST=qdrant
# RABBITMQ_HOST=rabbitmq

# Production domain
# DOMAIN=your-domain.com

# Enable SSL
# SSL_ENABLED=true
# SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
# SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# =============================================================================
# Whisper Voice Transcription (openai-whisper — local, PyTorch)
# Requires: sudo apt install ffmpeg && pip install openai-whisper
# =============================================================================
# Legacy YAML/docs: WHISPER_MODEL (local short voice uses WHISPER_LOCAL_MODEL instead)
WHISPER_MODEL=large-v3
# Local model for short voice (duration ≤ WHISPER_LOCAL_MAX_DURATION_SECONDS): medium recommended
WHISPER_LOCAL_MODEL=medium
# Route: at or below this duration (seconds) → local Whisper; above or unknown → cloud STT
WHISPER_LOCAL_MAX_DURATION_SECONDS=30
# Cloud STT: openrouter | yandex | openrouter_then_yandex (try OpenRouter, then Yandex on failure)
WHISPER_REMOTE_BACKEND=openrouter_then_yandex
# OpenRouter multimodal STT (audio input); pick a model with audio modality on openrouter.ai/models
WHISPER_OPENROUTER_STT_MODEL=google/gemini-2.0-flash-001
# WHISPER_OPENROUTER_STT_TIMEOUT_SECONDS=300
# Yandex SpeechKit (can differ from Yandex Search key — same Cloud folder often works)
# YANDEX_SPEECH_API_KEY=
# YANDEX_SPEECH_FOLDER_ID=   # defaults to YANDEX_FOLDER_ID
# WHISPER_YANDEX_STT_TIMEOUT_SECONDS=300
# Device: cpu | cuda
WHISPER_DEVICE=cpu
# fp16 decode: omit for auto (true on cuda, false on cpu); or set true/false
# WHISPER_FP16=
# Quality / speed (openai-whisper decode): higher = slower
WHISPER_BEAM_SIZE=10
WHISPER_BEST_OF=5
WHISPER_PATIENCE=2.0
# Language: ru, en, ... — leave empty for auto-detect
WHISPER_LANGUAGE=ru
# LLM correction after Whisper: tries chat model first, then this (cheap paid, not :free)
WHISPER_CORRECTION_FALLBACK_MODEL=openrouter/minimax/minimax-m2.5
# WHISPER_CORRECTION_TIMEOUT_SECONDS=120
# Pre-download weights (avoids blocking first voice): ENV=prod python scripts/prefetch_whisper.py
# Or: make whisper-prefetch

# =============================================================================
# Search Skills (optional, enable in config/providers.yaml)
# =============================================================================
# Tavily AI Search API key — best for AI agents (https://tavily.com/)
# Free tier: ~1000 searches/month. Enable: skills.web_search.providers.tavily.enabled: true
TAVILY_API_KEY=

# Yandex XML Search — great for Russian-language queries (https://yandex.ru/dev/xml/)
# Register at yandex.ru, get the key in your Yandex account → "Yandex XML"
# Enable: skills.web_search.providers.yandex.enabled: true
# Yandex Search API v2 (Yandex Cloud / AI Studio)
# Key: console.yandex.cloud → IAM → Service accounts → API keys (starts with AQVN...)
YANDEX_SEARCH_KEY=
# Folder ID: console.yandex.cloud → Resource Manager → select folder → copy ID (starts with b1g...)
YANDEX_FOLDER_ID=
# Legacy XML API username (no longer used)
YANDEX_SEARCH_USER=

# Brave Search API key (https://brave.com/search/api/)
# $3/month = 2000 queries. Enable: skills.web_search.providers.brave.enabled: true
BRAVE_SEARCH_KEY=

# =============================================================================
# Blogger Service
# =============================================================================
# Port for the blogger FastAPI service
# Dev:  8105
# Prod: 18105
BLOGGER_SERVICE_PORT=8105
# Optional base URL for HTTP (delegation from orchestrator). Default: http://127.0.0.1:BLOGGER_SERVICE_PORT
# BLOGGER_SERVICE_URL=http://127.0.0.1:8105

# Shared secret for POST /api/v1/agent/execute between services (orchestrator -> coder/blogger).
# Leave unset in local dev to skip header checks.
# DELEGATION_SHARED_SECRET=

# Your personal Telegram user_id (integer).
# The business bot ONLY responds to this user in private chats.
# All other users are silently ignored — the bot does not reveal itself to strangers.
# Find your ID via @userinfobot in Telegram.
OWNER_TELEGRAM_ID=

# Telegram bot token for the "silent" business monitoring bot + evening check-in DMs.
# HOW TO SET UP:
#   1. Create a new bot via @BotFather → /newbot
#   2. Copy the token and paste it here (in .env.prod only, never in git)
#   3. Add this bot to your business Telegram groups as a member (not admin)
#   4. Send /start to the bot in private chat to activate DM channel
#   5. Register each group: /register_business_chat <group_id> <name> [initials|roles|full]
BUSINESS_BOT_TOKEN=

# Telegram channel IDs for post publishing.
# HOW TO GET CHANNEL ID:
#   1. Add the MAIN bot (@your_orchestrator_bot) as administrator to each channel
#   2. Forward any message from the channel to @userinfobot — it shows the chat_id
#   3. Channel IDs look like: -1001234567890
BLOGGER_CHANNEL_RU=
BLOGGER_CHANNEL_EN=
BLOGGER_CHANNEL_PERSONAL=

# =============================================================================
# Optional Services (for future)
# =============================================================================
# Sentry DSN for error tracking
# SENTRY_DSN=

# Prometheus metrics
# PROMETHEUS_ENABLED=false
# PROMETHEUS_PORT=9090

# Email notifications
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
