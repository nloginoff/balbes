# Production Environment Configuration

# Environment
ENV=prod
DEBUG=false

# PostgreSQL (production, isolated from dev)
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_USER=balbes
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=balbes

# Redis (production with password, isolated from dev)
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
REDIS_PREFIX=prod

# Qdrant (production with API key, isolated from dev)
QDRANT_HOST=localhost
QDRANT_PORT=16333
QDRANT_GRPC_PORT=16334
QDRANT_API_KEY=CHANGE_ME_QDRANT_API_KEY_HERE
QDRANT_COLLECTION_PREFIX=prod

# RabbitMQ (production, isolated from dev)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=15673
RABBITMQ_MANAGEMENT_PORT=15674
RABBITMQ_USER=CHANGE_ME_RABBITMQ_USER
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD_HERE
RABBITMQ_VHOST=/

# Service Ports (Production app layer, isolated from dev)
MEMORY_SERVICE_PORT=18100
SKILLS_REGISTRY_PORT=18101
ORCHESTRATOR_PORT=18102
CODER_PORT=18103
WEB_BACKEND_PORT=18200

# Service URLs
MEMORY_SERVICE_URL=http://localhost:18100
SKILLS_REGISTRY_URL=http://localhost:18101
ORCHESTRATOR_URL=http://localhost:18102
CODER_URL=http://localhost:18103

# Frontend (served by Nginx on port 80/443)
FRONTEND_PORT=80

# API Keys (PRODUCTION - MUST CHANGE!)
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_API_KEY_HERE
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN_HERE
WEB_AUTH_TOKEN=CHANGE_ME_WEB_AUTH_TOKEN_HERE

# JWT (PRODUCTION - MUST BE STRONG!)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Logging
LOG_LEVEL=INFO

# Security
ALLOWED_ORIGINS=https://yourdomain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
