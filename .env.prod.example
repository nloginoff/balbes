# Production Environment Configuration

# Environment
ENV=prod
DEBUG=false

# PostgreSQL (production, isolated from dev)
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_USER=balbes
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=balbes

# Redis (production with password, isolated from dev)
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
REDIS_PREFIX=prod

# Qdrant (production with API key, isolated from dev)
QDRANT_HOST=localhost
QDRANT_PORT=16333
QDRANT_GRPC_PORT=16334
QDRANT_API_KEY=CHANGE_ME_QDRANT_API_KEY_HERE
QDRANT_COLLECTION_PREFIX=prod

# RabbitMQ (production, isolated from dev)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=15673
RABBITMQ_MANAGEMENT_PORT=15674
RABBITMQ_USER=CHANGE_ME_RABBITMQ_USER
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD_HERE
RABBITMQ_VHOST=/

# Service Ports (Production app layer, isolated from dev)
MEMORY_SERVICE_PORT=18100
SKILLS_REGISTRY_PORT=18101
ORCHESTRATOR_PORT=18102
CODER_PORT=18103
BLOGGER_SERVICE_PORT=18105
WEB_BACKEND_PORT=18200

# Service URLs
MEMORY_SERVICE_URL=http://localhost:18100
SKILLS_REGISTRY_URL=http://localhost:18101
ORCHESTRATOR_URL=http://localhost:18102
CODER_URL=http://localhost:18103
BLOGGER_SERVICE_URL=http://localhost:18105

# Frontend (served by Nginx on port 80/443)
FRONTEND_PORT=80

# API Keys (PRODUCTION - MUST CHANGE!)
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_API_KEY_HERE
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN_HERE
WEB_AUTH_TOKEN=CHANGE_ME_WEB_AUTH_TOKEN_HERE
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=CHANGE_ME_WEB_ADMIN_PASSWORD_HERE

# Telegram User IDs
# Your personal Telegram user_id — main bot only responds to these IDs.
# Get your ID from @userinfobot in Telegram.
TELEGRAM_USER_ID=CHANGE_ME_YOUR_TELEGRAM_USER_ID

# Blogger Agent (PRODUCTION - fill in to enable)
# Your Telegram user_id (integer) — business bot ONLY responds to this account.
# All other private messages are silently ignored for security.
OWNER_TELEGRAM_ID=CHANGE_ME_YOUR_TELEGRAM_USER_ID

# Separate bot for business group monitoring + evening check-in DMs.
# Create via @BotFather, add to business groups, send /start in private chat.
# NEVER commit this token to git — add it directly here in .env.prod.
BUSINESS_BOT_TOKEN=

# Telegram channel IDs where posts will be published (format: -1001234567890).
# Add the MAIN bot (TELEGRAM_BOT_TOKEN) as administrator to each channel.
# Get channel ID by forwarding a channel message to @userinfobot.
BLOGGER_CHANNEL_RU=
BLOGGER_CHANNEL_EN=
BLOGGER_CHANNEL_PERSONAL=

# =============================================================================
# Webhooks gateway (services/webhooks_gateway — Telegram / MAX / monitoring notify)
# =============================================================================
WEBHOOKS_GATEWAY_PORT=18180
TELEGRAM_BOT_MODE=polling
TELEGRAM_WEBHOOK_SECRET=
MAX_WEBHOOK_SECRET=
WEBHOOK_NOTIFY_API_KEY=
NOTIFY_DELIVERY_CHANNELS=telegram
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_RATE_LIMIT_PER_MINUTE=60
MAX_BOT_TOKEN=
MAX_API_URL=https://platform-api.max.ru
# MAX: для лички с пользователем задайте NOTIFY_MAX_USER_ID (API POST /messages?user_id=).
NOTIFY_MAX_USER_ID=
# Или чат/группа: NOTIFY_MAX_CHAT_ID (POST /messages?chat_id=).
NOTIFY_MAX_CHAT_ID=
# Входящие MAX: только эти user_id (через запятую). Пусто = без ограничения.
MAX_ALLOWED_USER_IDS=
# Зеркалирование ответов в связанный мессенджер при недавней активности канала
# AGENT_REPLY_MIRROR_ENABLED=true
# AGENT_REPLY_MIRROR_PRESENCE_TTL_SECONDS=3600
# Разрешённые цели (identity-провайдеры), через запятую; по умолчанию telegram,max. Пусто = никуда не дублировать.
# AGENT_REPLY_MIRROR_PROVIDERS=telegram,max

# Dashboard CORS (comma-separated); often matches ALLOWED_ORIGINS
CORS_ORIGINS=https://yourdomain.com

# Optional: orchestrator → coder/blogger HTTP trust
# DELEGATION_SHARED_SECRET=

# Optional: fallback LLM provider
# AITUNNEL_API_KEY=

# JWT (PRODUCTION - MUST BE STRONG!)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Logging
LOG_LEVEL=INFO

# Security
ALLOWED_ORIGINS=https://yourdomain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
